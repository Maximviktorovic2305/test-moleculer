{
  "name": "notes-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Notes microservice backend (Moleculer + TypeScript + TypeORM)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier \"src/**/*.ts\" \"test/**/*.ts\" --write",
    "format:check": "prettier \"src/**/*.ts\" \"test/**/*.ts\" --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typeorm": "typeorm-ts-node-commonjs -d src/db/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.2",
    "moleculer": "^0.14.35",
    "moleculer-web": "^0.10.8",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "winston": "^3.19.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "pg-mem": "^3.0.14",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
