PORT=3000
LOG_LEVEL=info
LOG_PRETTY=true
LOG_TO_FILE=false
LOG_DIR=./logs
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_SKIP_PATHS=/health
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=notes_db
DB_USER=postgres
DB_PASSWORD=admin
DB_SYNC=false
DB_RUN_MIGRATIONS=true

JWT_SECRET=secret123-secret123-secret123
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=refresh123-refresh123-refresh123
REFRESH_TOKEN_EXPIRES_IN=7d
