# Root-level env values used by docker-compose.yml

# Ports on host machine
POSTGRES_PORT=
BACKEND_PORT=
FRONTEND_PORT=

# Postgres
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Backend runtime
NODE_ENV=
LOG_LEVEL=
RATE_LIMIT_ENABLED=
RATE_LIMIT_MAX_REQUESTS=
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_SKIP_PATHS=
CORS_ORIGIN=
DB_SYNC=
DB_RUN_MIGRATIONS=
JWT_SECRET=
JWT_EXPIRES_IN=
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=

# Frontend build-time API base URL for Docker image
VITE_API_URL=
