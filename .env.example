# Root-level env values used by docker-compose.yml

# Ports on host machine
POSTGRES_PORT=5432
BACKEND_PORT=3000
FRONTEND_PORT=8080

# Postgres
POSTGRES_DB=notes_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-db-password

# Backend runtime
NODE_ENV=production
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_SKIP_PATHS=/health
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
DB_SYNC=false
DB_RUN_MIGRATIONS=true
JWT_SECRET=change-me-jwt-secret-at-least-16-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-refresh-secret-at-least-16-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# Frontend build-time API base URL for Docker image
VITE_API_URL=http://localhost:3000
